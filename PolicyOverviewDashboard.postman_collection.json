{
  "info": {
    "name": "PolicyOverviewDashboard API v1",
    "description": "Postman collection for the Policy Overview Dashboard (GET/PATCH /api/v1/policies). Self-contained: the first request captures a real policy UUID into a collection variable that later requests reuse.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081", "type": "string" },
    { "key": "policyId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "List policies (page 0, size 5)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('has pagination metadata', () => {",
              "  pm.expect(body).to.have.property('totalElements');",
              "  pm.expect(body).to.have.property('totalPages');",
              "  pm.expect(body).to.have.property('content');",
              "});",
              "pm.test('page size respected (<=5)', () => pm.expect(body.content.length).to.be.at.most(5));",
              "pm.test('each policy has schema fields', () => {",
              "  const p = body.content[0];",
              "  ['id','policyNumber','policyholderName','lineOfBusiness','status','premiumAmount','currency','effectiveDate','expiryDate','region','underwriter','flaggedForReview','isExpiringSoon'].forEach(f => pm.expect(p, f).to.have.property(f));",
              "});",
              "if (body.content.length) { pm.collectionVariables.set('policyId', body.content[0].id); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies?page=0&size=5",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies"],
          "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "5" }]
        }
      }
    },
    {
      "name": "Get policy by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('returned id matches requested', () => pm.expect(body.id).to.eql(pm.collectionVariables.get('policyId')));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies/{{policyId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies", "{{policyId}}"]
        }
      }
    },
    {
      "name": "Filter by status=ACTIVE",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('every result is Active', () => body.content.forEach(p => pm.expect(p.status).to.eql('Active')));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies?status=ACTIVE&page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies"],
          "query": [
            { "key": "status", "value": "ACTIVE" },
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" }
          ]
        }
      }
    },
    {
      "name": "Filter by region + lineOfBusiness",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('every result matches region and LOB', () => body.content.forEach(p => {",
              "  pm.expect(p.region).to.eql('Japan');",
              "  pm.expect(p.lineOfBusiness).to.eql('Marine');",
              "}));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies?region=JAPAN&lineOfBusiness=MARINE&page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies"],
          "query": [
            { "key": "region", "value": "JAPAN" },
            { "key": "lineOfBusiness", "value": "MARINE" },
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" }
          ]
        }
      }
    },
    {
      "name": "Effective date range",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('effectiveDate within range', () => body.content.forEach(p => {",
              "  pm.expect(p.effectiveDate >= '2024-01-01').to.be.true;",
              "  pm.expect(p.effectiveDate <= '2024-12-31').to.be.true;",
              "}));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies?effectiveDateFrom=2024-01-01&effectiveDateTo=2024-12-31&page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies"],
          "query": [
            { "key": "effectiveDateFrom", "value": "2024-01-01" },
            { "key": "effectiveDateTo", "value": "2024-12-31" },
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" }
          ]
        }
      }
    },
    {
      "name": "Free-text search (underwriter)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('results returned for search', () => pm.expect(body.totalElements).to.be.above(0));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies?search=Acme&page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies"],
          "query": [
            { "key": "search", "value": "Acme" },
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" }
          ]
        }
      }
    },
    {
      "name": "Sort by premiumAmount desc",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('descending by premiumAmount', () => {",
              "  for (let i = 1; i < body.content.length; i++) {",
              "    pm.expect(body.content[i-1].premiumAmount).to.be.at.least(body.content[i].premiumAmount);",
              "  }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies?sort=premiumAmount,desc&page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies"],
          "query": [
            { "key": "sort", "value": "premiumAmount,desc" },
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" }
          ]
        }
      }
    },
    {
      "name": "PATCH flag policy for review",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('flaggedCount is 1', () => pm.expect(body.flaggedCount).to.eql(1));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"policyIds\": [\"{{policyId}}\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies/flag",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies", "flag"]
        }
      }
    },
    {
      "name": "Verify policy is flagged",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('flaggedForReview is true', () => pm.expect(body.flaggedForReview).to.be.true);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies/{{policyId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies", "{{policyId}}"]
        }
      }
    },
    {
      "name": "Summary statistics",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('has countsByStatus', () => pm.expect(body.countsByStatus).to.be.an('object'));",
              "pm.test('has totalPremiumByLineOfBusiness', () => pm.expect(body.totalPremiumByLineOfBusiness).to.be.an('object'));",
              "pm.test('has expiringSoonCount', () => pm.expect(body).to.have.property('expiringSoonCount'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies/summary",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies", "summary"]
        }
      }
    },
    {
      "name": "Get unknown id returns 404",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 404', () => pm.response.to.have.status(404));",
              "const body = pm.response.json();",
              "pm.test('error body has status 404', () => pm.expect(body.status).to.eql(404));",
              "pm.test('no stack trace exposed', () => pm.expect(body).to.not.have.property('trace'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Accept", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies/00000000-0000-0000-0000-000000000000",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies", "00000000-0000-0000-0000-000000000000"]
        }
      }
    },
    {
      "name": "Flag with empty ids returns 400",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 400', () => pm.response.to.have.status(400));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"policyIds\": []\n}" },
        "url": {
          "raw": "{{baseUrl}}/api/v1/policies/flag",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "policies", "flag"]
        }
      }
    }
  ]
}
