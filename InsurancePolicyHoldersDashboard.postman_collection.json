{
  "info": {
    "name": "InsurancePolicyHoldersDashboard",
    "description": "API collection for Insurance Policy Holders Dashboard",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Policy Holders",
      "item": [
        {
          "name": "Get All Policy Holders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policy-holders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policy-holders"]
            }
          }
        },
        {
          "name": "Get Policy Holder By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policy-holders/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policy-holders", "1"]
            }
          }
        },
        {
          "name": "Search Policy Holders By Last Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policy-holders?lastName=Smith",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policy-holders"],
              "query": [{ "key": "lastName", "value": "Smith" }]
            }
          }
        },
        {
          "name": "Create Policy Holder",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Alice\",\n  \"lastName\": \"Williams\",\n  \"email\": \"alice.williams@email.com\",\n  \"phone\": \"555-2001\",\n  \"dateOfBirth\": \"1992-05-10\",\n  \"address\": \"321 Elm Street, Houston, TX\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/policy-holders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policy-holders"]
            }
          }
        },
        {
          "name": "Update Policy Holder",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Alice\",\n  \"lastName\": \"Williams\",\n  \"email\": \"alice.updated@email.com\",\n  \"phone\": \"555-9999\",\n  \"dateOfBirth\": \"1992-05-10\",\n  \"address\": \"999 Updated Ave, Houston, TX\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/policy-holders/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policy-holders", "1"]
            }
          }
        },
        {
          "name": "Delete Policy Holder",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policy-holders/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policy-holders", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Policies",
      "item": [
        {
          "name": "Get All Policies (Paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policies?page=0&size=10&sort=startDate,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policies"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "startDate,desc" }
              ]
            }
          }
        },
        {
          "name": "Get Active Policies (Paginated + Filtered)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policies?status=ACTIVE&page=0&size=5&sort=startDate,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policies"],
              "query": [
                { "key": "status", "value": "ACTIVE" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "5" },
                { "key": "sort", "value": "startDate,desc" }
              ]
            }
          }
        },
        {
          "name": "Get Policy By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policies/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policies", "1"]
            }
          }
        },
        {
          "name": "Get Policies By Holder ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policies/holder/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policies", "holder", "1"]
            }
          }
        },
        {
          "name": "Get Policies By Status (ACTIVE)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policies?status=ACTIVE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policies"],
              "query": [{ "key": "status", "value": "ACTIVE" }]
            }
          }
        },
        {
          "name": "Create Policy for Holder",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyNumber\": \"POL-2024-005\",\n  \"policyType\": \"HEALTH\",\n  \"premiumAmount\": 175.00,\n  \"coverageAmount\": 200000.00,\n  \"startDate\": \"2024-06-01\",\n  \"endDate\": \"2025-06-01\",\n  \"status\": \"ACTIVE\",\n  \"region\": \"Northeast\",\n  \"currency\": \"USD\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/policies/holder/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policies", "holder", "1"]
            }
          }
        },
        {
          "name": "Update Policy Status",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policies/1/status?status=INACTIVE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policies", "1", "status"],
              "query": [{ "key": "status", "value": "INACTIVE" }]
            }
          }
        },
        {
          "name": "Delete Policy",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/policies/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "policies", "1"]
            }
          }
        }
      ]
    }
  ]
}
